FROM python:3.11-slim

LABEL org.opencontainers.image.source="https://github.com/run-house/kubetorch"
LABEL org.opencontainers.image.description="Kubetorch OSS"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Install dependencies
RUN apt-get update && \
    apt-get install -y git bash rsync && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY python_client /tmp/kubetorch/python_client

# Install the full Kubetorch stack from the checked-out repository.
RUN pip install "/tmp/kubetorch/python_client[client,server,otel]" && \
    rm -rf /tmp/kubetorch

# Verify installation
RUN python -c "import kubetorch; print('Kubetorch version:', kubetorch.__version__)"

# start a bash shell
CMD ["/bin/bash"]
